<?xml version="1.0" encoding="UTF-8"?>
<inkscape-extension xmlns="http://www.inkscape.org/namespace/inkscape/extension">
    <name>Inkpilot</name>
    <id>com.inkpilot.copilot</id>
    <effect needs-live-preview="false">
        <object-type>all</object-type>
        <effects-menu>
            <submenu name="Inkpilot"/>
        </effects-menu>
    </effect>
    <script>
        <command location="inx" interpreter="python">inkpilot_extension.py</command>
    </script>
</inkscape-extension>
